# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# NextAuth
AUTH_SECRET=your-nextauth-secret-32-chars-minimum
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Resend (resend.com)
RESEND_API_KEY=re_your_api_key

# Vercel Cron (generated random string, set in Vercel dashboard too)
CRON_SECRET=your-random-cron-secret

# Comma-separated emails that can have multiple profiles (e.g. admin + player)
MULTI_PROFILE_EMAILS=email1@example.com,email2@example.com

# Gmail SMTP (for sending emails via nodemailer)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# App URL (used in emails)
NEXT_PUBLIC_APP_URL=https://quincyassassins.vercel.app
